# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/military_attendance"

# Redis
REDIS_URL="redis://localhost:6379"

# API Configuration
API_PORT=3001
API_ENV="development"
API_URL="http://localhost:3001"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"

# JWT/Auth
JWT_SECRET="dev-secret-key-change-in-production"
JWT_EXPIRATION="24h"

# QR Token
QR_TOKEN_EXPIRATION_SECONDS=600
QR_TOKEN_REFRESH_INTERVAL_SECONDS=10

# Location Validation
LOCATION_VALIDATION_MODE="hybrid"
LOCATION_RADIUS_METERS=50

# Feature Toggles (Boolean: true/false)
FEATURE_AUTH_PIN=true
FEATURE_AUTH_OTP=false
FEATURE_AUTH_FACE=true
FEATURE_DETECTION_HIGH=true
FEATURE_DEVICE_STRICT=true

# Logging
LOG_LEVEL="info"

# Database migrations
DATABASE_MIGRATION_STATUS="dev"
